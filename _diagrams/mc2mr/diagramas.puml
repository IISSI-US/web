
@startuml ejercicio-01-universidad-clases
title Ejercicio 1: Universidad-Centro-Estudiante (Diagrama de Clases)

hide empty members
hide circle

class Universidad {
  nombre: String
  dirección: String
  fundacion: Date
}

class Centro {
  nombre: String
  codigo: String
  presupuesto: Double
}

class Estudiante {
  matrícula: String
  nombre: String
  edad: Integer
  promedio: Double
}

Universidad *-- Centro : contiene >
Centro "1" -- "0..*" Estudiante : inscribe >
@enduml


