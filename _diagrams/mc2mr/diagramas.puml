@startuml ejercicio-09-torneo-tenis-clases
title Ejercicio 9: Torneo de Tenis (Diagrama de Clases)

hide empty members
hide circle

class Persona {
  nombre: String
  apellido: String
  fechaNacimiento: Date
  nacionalidad: String
}

class Tenista {
  ranking: Integer
}

class Árbitro {
  licencia: String
}

class Partido {
  torneo: String
  fecha: Date
  ronda: String
  duracion: Integer
}

class Set {
  resultado: String
}

' Herencia completa disjunta
Persona <|-- Tenista
Persona <|-- Árbitro : {completa,disjunta}

' Relaciones
Tenista "0..*" -- "0..*" Tenista : juegaContra >
(Tenista, Tenista) .. Partido  
Tenista "0..1" -- "0..*" Partido : gana >
Árbitro "1" -- "0..*" Partido : arbitra >
Partido *-- "1..* {orden}" Set  
Tenista "1" -- "0..*" Set : gana >

@enduml
