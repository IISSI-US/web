@startuml
!option handwritten true
hide circle

skinparam classBackgroundColor #cccccc
skinparam classBorderColor #888888
skinparam classFontColor black
skinparam classFontSize 12
skinparam classFontStyle bold

' Enumerations
enum SubjectType <<Enumerado>> {
  Formación Básica
  Obligatoria
  Optativa
}

enum ActivityType <<Enumerado>> {
  Teoría
  Laboratorio
}

enum AccessType <<Enumerado>> {
  Selectividad
  Ciclo
  Mayor
  Titulado Extranjero
}

@enduml