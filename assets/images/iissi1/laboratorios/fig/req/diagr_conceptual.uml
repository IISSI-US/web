@startuml
!option handwritten true
hide circle
skinparam linetype ortho

skinparam classBackgroundColor #cccccc
skinparam classBorderColor #888888
skinparam classFontColor black
skinparam classFontSize 12
skinparam classFontStyle bold

skinparam noteBackgroundColor #b3e0ff
skinparam noteBorderColor #3399cc
skinparam noteFontColor #222222

class Degrees {
  name: String
  years: Natural
}

class Subjects {
  name: String
  acronym: String
  credits: Real
  year: Natural
  type: SubjectType
}

class Groups {
  name: String
  activity: ActivityType
  year: Natural
}

class Grades {
  value: Real
  gradeCall: Natural
  withHonours: Boolean
}

class Students {
  accessMethod: AccessType
  dni: String
  firstName: String
  surname: String
  birthDate: Date
  email: String
}

' Relationships with orthogonal lines
Degrees "1" -down- "*" Subjects : taughtIn <
Subjects " " *-down- "1..*" Groups
Groups "1" -down- "*" Grades : gotIn <
Students "*" -down- "*" Groups : belongsTo
Students "1" -down- "*" Grades : gets

' Notes
note right of Groups
- RN-006: A "Teoría" group should not have 
more than 75 students, and a "Laboratorio" one,
no more than 25.
- RN-007: A student may not belong to more
than one "Teoría" and "Laboratorio" group 
for each subject.
end note

note left of Students
- RN-003: A student cannot access through 
"Selectividad" being younger than 16 years 
old.
- RN-004: A student cannot have grades for
groups he doesn't belong to.
end note

note left of Grades
- RN-001: For a grade to be with honours, its 
value must be equal to or higher than 9.
- RN-002: A student must not have more than 
one grade per subject, call and academic year.
- RN-005: A grade may not be raised or lowered
by more than 4 points. 
end note

@enduml